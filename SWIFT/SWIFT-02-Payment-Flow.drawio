        </mxCell>
        <mxCell id="leg2_lbl" value="MT940 / CAMT.053  (end-of-day account statement — return)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=9;fontColor=#333333;" vertex="1" parent="1">
