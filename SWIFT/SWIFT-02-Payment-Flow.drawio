          <mxGeometry x="380" y="605" width="210" height="32" as="geometry" />
        </mxCell>
        <mxCell id="tl3" value="T+0–1  FX conversion + routing" style="rounded=4;whiteSpace=wrap;html=1;fillColor=#0070C0;strokeColor=#0070C0;fontColor=#FFFFFF;fontSize=8;" vertex="1" parent="1">
