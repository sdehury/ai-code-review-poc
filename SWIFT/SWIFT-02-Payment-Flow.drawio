        </mxCell>
        <mxCell id="leg1_lbl" value="MT103  (SWIFT FIN message — forward payment)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=9;fontColor=#333333;" vertex="1" parent="1">
