          <mxGeometry x="1100" y="545" width="20" height="20" as="geometry" />
        </mxCell>
        <mxCell id="leg3_lbl" value="Nostro / Vostro Account" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=9;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="1125" y="535" width="220" height="50" as="geometry" />
        </mxCell>

        <!-- ══ TIMELINE STRIP ══ -->
        <mxCell id="tl_title" value="Typical Timeline:" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=9;fontStyle=1;fontColor=#003372;" vertex="1" parent="1">
