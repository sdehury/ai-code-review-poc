# ── Database ──────────────────────────────────────────────────────────────────
DB_NAME=codereview
DB_USER=codereview
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Encryption ────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS_HERE_REPLACE_THIS_VALUE_WITH_REAL_ONE_NOW

# ── AI Provider ───────────────────────────────────────────────────────────────
# Options: anthropic | openai | disabled
AI_PROVIDER=disabled
AI_MODEL=claude-opus-4-6
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Scheduler ─────────────────────────────────────────────────────────────────
SCHEDULER_TIMEZONE=UTC
